ADMIN_PASSWORD=my_market_drawer
PORT=3009
# 0.0.0.0 = accept connections from any host (for hosting on a server/LAN)
HOST=0.0.0.0

# Public URL to include in Teams/Slack alert messages (optional).
# Example: APP_PUBLIC_URL=http://192.168.10.142:3009

# Optional: Webhook for "Uyarı gönder" alerts (Teams channel "Drawer" or Slack).
# For Teams: In the Drawer channel, add Connector → Incoming Webhook, then paste the URL here.
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
